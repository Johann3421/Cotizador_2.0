# =============================
# BASE DE DATOS
# =============================
DB_NAME=kenya_quotes
DB_USER=kenya
DB_PASSWORD=TU_PASSWORD_SEGURO_AQUI

# =============================
# AI API — CONECTA TU PROPIA KEY
# =============================
# Proveedores soportados: openai | anthropic
AI_PROVIDER=openai
AI_API_KEY=sk-...
AI_MODEL=gpt-4o
# Para Anthropic:
# AI_PROVIDER=anthropic
# AI_API_KEY=sk-ant-...
# AI_MODEL=claude-sonnet-4-5

# =============================
# APP
# =============================
NODE_ENV=production
PORT=3001
MAX_FILE_SIZE_MB=10
QUOTE_PREFIX=KEN

# =============================
# SCRAPER — PeruCompras
# =============================
# Ruta al ejecutable de Chromium (en contenedor Docker)
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium-browser
# pressSequentially: espera tras terminar de tipear (ms)
SCRAPER_WAIT_TYPING=500
# Tiempo máximo esperando que aparezcan resultados (ms)
SCRAPER_WAIT_RESULTS=8000
# Pausa entre búsquedas de marcas distintas — rate limiting (ms)
SCRAPER_WAIT_BRANDS=3000
