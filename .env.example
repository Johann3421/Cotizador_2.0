# =============================
# BASE DE DATOS
# =============================
DB_NAME=kenya_quotes
DB_USER=kenya
DB_PASSWORD=TU_PASSWORD_SEGURO_AQUI

# =============================
# AI API — CONECTA TU PROPIA KEY
# =============================
# Proveedores soportados: openai | anthropic
AI_PROVIDER=openai
AI_API_KEY=sk-...
AI_MODEL=gpt-4o
# Para Anthropic:
# AI_PROVIDER=anthropic
# AI_API_KEY=sk-ant-...
# AI_MODEL=claude-sonnet-4-5

# =============================
# APP
# =============================
NODE_ENV=production
PORT=3001
MAX_FILE_SIZE_MB=10
QUOTE_PREFIX=KEN
