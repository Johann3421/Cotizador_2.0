# =============================
# BASE DE DATOS
# =============================
DB_NAME=kenya_quotes
DB_USER=kenya
DB_PASSWORD=TU_PASSWORD_SEGURO_AQUI

# =============================
# AI API — CONECTA TU PROPIA KEY
# =============================
# Proveedores soportados: openai | anthropic
AI_PROVIDER=openai
AI_API_KEY=sk-...
AI_MODEL=gpt-4o
# Para Anthropic:
# AI_PROVIDER=anthropic
# AI_API_KEY=sk-ant-...
# AI_MODEL=claude-sonnet-4-5

# =============================
# AUTH — JWT
# =============================
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=              # ← OBLIGATORIO — dejar vacío rompe el login
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# =============================
# URLS
# =============================
FRONTEND_URL=https://cotizador.abadgroup.tech
CORS_ORIGIN=https://cotizador.abadgroup.tech

# =============================
# EMAIL (opcional)
# Si se deja vacío los emails se omiten silenciosamente
# =============================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=Kenya Cotizador <no-reply@kenya.com>

# =============================
# APP
# =============================
NODE_ENV=production
PORT=3001
MAX_FILE_SIZE_MB=10
QUOTE_PREFIX=KEN

# =============================
# SCRAPER — PeruCompras
# =============================
# Ruta al ejecutable de Chromium (en contenedor Docker)
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium-browser
# pressSequentially: espera tras terminar de tipear (ms)
SCRAPER_WAIT_TYPING=500
# Tiempo máximo esperando que aparezcan resultados (ms)
SCRAPER_WAIT_RESULTS=8000
# Pausa entre búsquedas de marcas distintas — rate limiting (ms)
SCRAPER_WAIT_BRANDS=3000
