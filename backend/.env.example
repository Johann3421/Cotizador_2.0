# =============================
# BASE DE DATOS
# =============================
DB_NAME=kenya_quotes
DB_USER=kenya
DB_PASSWORD=TU_PASSWORD_SEGURO_AQUI

# =============================
# AI API — CONECTA TU PROPIA KEY
# =============================
AI_PROVIDER=openai          # Cambiar a: anthropic
AI_API_KEY=sk-...           # Tu API key aquí
AI_MODEL=gpt-4o             # o claude-sonnet-4-5

# =============================
# APP
# =============================
NODE_ENV=production
PORT=3001
MAX_FILE_SIZE_MB=10
QUOTE_PREFIX=KEN
BCRYPT_ROUNDS=10

# =============================
# SEGURIDAD — ADMIN
# =============================
# Secret para endpoint POST /api/admin/init-superadmin (rescate de conta)
# Cambiar a valor secreto aleatorio en producción (no usar EMPTY_DO_NOT_USE)
ADMIN_INIT_SECRET=EMPTY_DO_NOT_USE
